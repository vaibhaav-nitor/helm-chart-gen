# Use either OpenAI or Azure OpenAI.
#
# OpenAI:
# OPENAI_API_KEY=your_openai_api_key
# MODEL=gpt-4o
#
# Azure OpenAI:
AZURE_API_KEY=your_azure_openai_key
AZURE_API_BASE=https://your-resource.openai.azure.com/
AZURE_API_VERSION=2024-12-01-preview
MODEL=azure/your-deployment-name

CREWAI_STORAGE_DIR=D:\Crew-ai\helm_chart_gen\.crewai_storage

HELM_GEN_REPOSITORY_URL=https://github.com/crewAIInc/crewAI-examples.git
HELM_GEN_GIT_REF=main
HELM_GEN_APP_SUBDIRECTORY=
HELM_GEN_CHART_NAME=generated-app
HELM_GEN_RELEASE_NAME=generated-app
HELM_GEN_NAMESPACE=default
HELM_GEN_IMAGE_REPOSITORY=example.azurecr.io/generated-app
HELM_GEN_IMAGE_TAG=0.1.0
HELM_GEN_CONTAINER_PORT=
HELM_GEN_INGRESS_ENABLED=false
HELM_GEN_INGRESS_HOST=
HELM_GEN_AKS_CLUSTER_NAME=
HELM_GEN_AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
HELM_GEN_KEYVAULT_NAME=placeholder-keyvault
HELM_GEN_USER_ASSIGNED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000
HELM_GEN_SECRET_MAPPINGS_JSON=[]
HELM_GEN_CONFIG_VALUES_JSON={}
HELM_GEN_ENABLE_HPA=false
HELM_GEN_MIN_REPLICAS=2
HELM_GEN_MAX_REPLICAS=5
